{
  "services": {
    "web": {
      "root": "apps/web"
    },
    "api": {
      "root": "apps/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}